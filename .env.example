# Copy to .env at repo root and fill in. The chat backend reads this on startup.
#
# Chat model provider resolution (see app/backend/chat.py):
#   ASKPLC_MOCK=1            -> deterministic mock (no model, no network)
#   ASKPLC_PROVIDER=...      -> explicit: subscription | api | mock
#   else ANTHROPIC_API_KEY   -> Anthropic API
#   else `claude` CLI found  -> subscription (your local Claude Code login;
#                               real Claude, zero API billing)
#   else                     -> mock

# Anthropic API key (only needed for provider=api; chat, auto-doc, and the
# eval all run on the Claude Code subscription without one).
ANTHROPIC_API_KEY=

# Chat model (default: claude-sonnet-5).
ASKPLC_MODEL=claude-sonnet-5

# Force the deterministic fake model: 1 = mock.
ASKPLC_MOCK=0

# Explicit provider: subscription | api | mock (blank = auto-resolve).
ASKPLC_PROVIDER=
