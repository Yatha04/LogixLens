# Copy to .env at repo root and fill in. The chat backend reads this on startup.
# Everything except live Claude calls works without a key (use ASKPLC_MOCK=1).

# Anthropic API key for the chat tool-loop (real model). Leave unset for mock mode.
ANTHROPIC_API_KEY=

# Chat model (default: claude-sonnet-5).
ASKPLC_MODEL=claude-sonnet-5

# Force the deterministic fake model (no API key needed): 1 = mock.
ASKPLC_MOCK=0
